generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CustomerRank {
  S
  A
  B
  C
}

enum RankSource {
  auto
  manual
}

enum CandidateOverallStatus {
  NEW
  FIRST_CONTACTED
  INTERVIEWED
  PROPOSING
  IN_PROGRESS
  OFFERED
  ACCEPTED
  JOINED
  ON_HOLD
  DROPPED
  CLOSED
}

enum SelectionStatus {
  PROPOSED
  WAITING_ENTRY
  ENTERED
  DOCUMENT_SCREENING
  PASSED_DOCUMENT
  FIRST_INTERVIEW_ADJUSTING
  FIRST_INTERVIEW_DONE
  SECOND_INTERVIEW_ADJUSTING
  SECOND_INTERVIEW_DONE
  IN_PROGRESS_OTHER
  OFFERED
  OFFERED_NO_SCHEDULE
  ACCEPTED
  JOINING_SCHEDULED
  JOINED
  DECLINED_BEFORE_DOCUMENT
  DECLINED_FIRST_INTERVIEW
  DECLINED_SECOND_INTERVIEW
  DECLINED_THIRD_INTERVIEW
  DECLINED_FINAL_INTERVIEW
  DECLINED_OTHER
  DECLINED_OFFER
  DECLINED
  REJECTED_DOCUMENT
  REJECTED_FIRST_INTERVIEW
  REJECTED_SECOND_INTERVIEW
  REJECTED_THIRD_INTERVIEW
  REJECTED_OTHER
  REJECTED
  CLOSED
}

enum GoalPeriodType {
  yearly
  monthly
}

enum MasterScope {
  candidate
  selection
}

model Candidate {
  id                        String                 @id @default(cuid())
  candidateCode             String                 @unique
  name                      String
  nameKana                  String?
  birthDate                 DateTime?
  gender                    String?
  age                       Int?
  postalCode                String?
  address                   String?
  addressKana               String?
  phone                     String?
  email                     String?
  nearestStation            String?
  commuteTime               String?
  dependentsCount           Int?                   @default(0)
  spouseStatus              String?
  photoPath                 String?
  contactPostalCode         String?
  contactAddress            String?
  contactAddressKana        String?
  contactPhone              String?
  currentAnnualIncome       Int?
  desiredAnnualIncome       Int?
  employmentStatus          String?
  jobSearchStatus           String?
  desiredTiming             String?
  desiredJobType            String?
  desiredJobTypeSecond      String?
  desiredLocation           String?
  desiredPrefecture         String?
  desiredCity              String?
  desiredLocationDetail    String?
  employmentTypePreference  String?
  careerAxisPrimary         String?
  careerAxisSecondary       String?
  availability              String?
  otherConditions           String?
  resumePreferenceText      String?
  finalEducation           String?
  experienceCompanyCount   Int?
  currentJobType           String?
  managementExperience      String?
  circusExperiencedIndustry String?
  circusExperiencedJobType  String?
  pcSkills                  String?
  languageSkills            String?
  transferableSkills        String?
  strengths                 String?
  reasonForChange           String?
  healthNote                String?
  tattooNote                String?
  symptomNote               String?
  surgeryNote               String?
  moneyNote                 String?
  qualificationText         String?
  qualificationCategory     String?
  customerRank              CustomerRank           @default(C)
  rankAutoResult            CustomerRank           @default(C)
  rankSource                RankSource             @default(auto)
  rankManualOverride        Boolean                @default(false)
  initialOwnerName          String?
  ownerName                 String?
  inflowSource              String?
  unemploymentInsuranceContract String?
  retirementDate            DateTime?
  resignationDate           DateTime?
  resignationPlannedDate    DateTime?
  agentPassDate             DateTime?
  callPreferredAt           DateTime?
  inflowDate                DateTime?
  firstResponseDate         DateTime?
  interviewDate             DateTime?
  proposalDate              DateTime?
  documentCreatedDate       DateTime?
  entryDate                 DateTime?
  companyInterviewDate      DateTime?
  offerDate                 DateTime?
  offerAcceptedDate         DateTime?
  joiningDate               DateTime?
  closedDate                DateTime?
  overallStatus             CandidateOverallStatus @default(NEW)
  proposalCount             Int                    @default(0)
  activeSelectionCount      Int                    @default(0)
  internalMemo              String?
  archived                  Boolean                @default(false)
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  educations          Education[]
  workHistories       WorkHistory[]
  qualifications      Qualification[]
  companyProfiles     CandidateCompanyProfile[]
  attachments         Attachment[]
  contactLogs         ContactLog[]
  selections          Selection[]

  @@index([customerRank])
  @@index([overallStatus])
  @@index([initialOwnerName])
  @@index([ownerName])
  @@index([inflowDate])
}

model Education {
  id          String    @id @default(cuid())
  candidateId String
  year        Int
  month       Int
  category    String
  schoolName  String
  sortOrder   Int       @default(0)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model WorkHistory {
  id              String    @id @default(cuid())
  candidateId     String
  joinedYear      Int
  joinedMonth     Int
  leftYear        Int?
  leftMonth       Int?
  isCurrent       Boolean   @default(false)
  companyName     String
  industry        String?
  employeeCount   String?
  departmentRole  String?
  employmentType  String?
  workDescription String?
  achievements    String?
  advisorMemo     String?
  sortOrder       Int       @default(0)
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model Qualification {
  id                String    @id @default(cuid())
  candidateId       String
  qualificationName String
  acquiredYear      Int?
  acquiredMonth     Int?
  isRankRelevant    Boolean   @default(false)
  notes             String?
  sortOrder         Int       @default(0)
  candidate         Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model CandidateCompanyProfile {
  id          String    @id @default(cuid())
  candidateId String
  companyName String
  selfPr      String?
  motivation  String?
  sortOrder   Int       @default(0)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model ContactLog {
  id                  String    @id @default(cuid())
  candidateId         String
  respondedAt         DateTime?
  respondentName      String?
  responseStatus      String?
  direction           String?
  communicationMethod String?
  reason              String?
  naAt                DateTime?
  naContent           String?
  isUnreachable       Boolean   @default(false)
  notes               String?
  createdAt           DateTime  @default(now())
  candidate           Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
}

model Attachment {
  id          String    @id @default(cuid())
  candidateId String
  name        String
  filePath    String
  mimeType    String?
  isOutput    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model Selection {
  id                   String          @id @default(cuid())
  candidateId          String
  companyName          String
  applicantName        String?
  applicationDate      DateTime?
  jobType              String?
  referralSource       String?
  jobPostingUrl        String?
  unitPrice            Int?
  feeRate              Float?
  selectionStatus      SelectionStatus @default(PROPOSED)
  statusUpdatedAt      DateTime?
  nextActionAt         DateTime?
  ownerName            String?
  proposedAt           DateTime?
  entryAt              DateTime?
  passedAt             DateTime?
  interviewScheduledAt DateTime?
  firstInterviewAt     DateTime?
  secondInterviewAt    DateTime?
  offerAt              DateTime?
  offerAcceptedAt      DateTime?
  joiningAt            DateTime?
  closedAt             DateTime?
  declinedAt           DateTime?
  rejectedAt           DateTime?
  lossReason           String?
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  candidate            Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([selectionStatus])
  @@index([ownerName])
  @@index([companyName])
}

model GoalSetting {
  id                    String         @id @default(cuid())
  periodType            GoalPeriodType
  year                  Int
  month                 Int            @default(0)
  annualRevenueTarget   Int?
  monthlyRevenueTarget  Int?
  averageUnitPrice      Int            @default(800000)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@unique([periodType, year, month])
}

model QualificationMaster {
  id           String       @id @default(cuid())
  name         String       @unique
  rankCategory CustomerRank
  isActive     Boolean      @default(true)
  sortOrder    Int          @default(0)
}

model StatusMaster {
  id        String      @id @default(cuid())
  scope     MasterScope
  code      String
  label     String
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)

  @@unique([scope, code])
}
